<UserControl x:Class="CalorieCounter.Views.DashboardView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Grid>
        <Grid.RowDefinitions><RowDefinition Height="Auto"/><RowDefinition Height="Auto"/><RowDefinition Height="*"/></Grid.RowDefinitions>
        <TextBlock Text="Дашборд" FontSize="28" FontWeight="Bold"/>
        <TextBlock Grid.Row="0" Text="{Binding Today, StringFormat='{}{0:dd MMMM yyyy}'}" Margin="180,6,0,0" VerticalAlignment="Center"/>
        <Border Grid.Row="1" Background="#2E3140" CornerRadius="12" Padding="16" Margin="0,10,0,10">
            <StackPanel>
                <TextBlock Text="Калории за сегодня" FontSize="18"/>
                <TextBlock Text="{Binding ConsumedCalories, StringFormat='{}{0:0} ккал'}" FontSize="36" FontWeight="Bold"/>
                <TextBlock Text="{Binding RemainingCalories, StringFormat='Осталось: {0:0} ккал'}"/>
                <ProgressBar Value="{Binding Progress}" Maximum="100" Height="18" Margin="0,8"/>
            </StackPanel>
        </Border>
        <UniformGrid Grid.Row="2" Columns="3" Margin="0,8,0,0">
            <Border Background="#2E3140" CornerRadius="10" Margin="4" Padding="10"><StackPanel><TextBlock Text="Белки"/><TextBlock Text="{Binding Protein, StringFormat='{}{0:0.0} г'}" FontSize="22"/></StackPanel></Border>
            <Border Background="#2E3140" CornerRadius="10" Margin="4" Padding="10"><StackPanel><TextBlock Text="Жиры"/><TextBlock Text="{Binding Fat, StringFormat='{}{0:0.0} г'}" FontSize="22"/></StackPanel></Border>
            <Border Background="#2E3140" CornerRadius="10" Margin="4" Padding="10"><StackPanel><TextBlock Text="Углеводы"/><TextBlock Text="{Binding Carbs, StringFormat='{}{0:0.0} г'}" FontSize="22"/></StackPanel></Border>
        </UniformGrid>
    </Grid>
</UserControl>
