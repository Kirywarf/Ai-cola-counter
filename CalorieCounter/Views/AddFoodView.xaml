<UserControl x:Class="CalorieCounter.Views.AddFoodView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <ScrollViewer>
        <StackPanel>
            <TextBlock Text="Добавить еду" FontSize="26" FontWeight="Bold" Margin="0,0,0,10"/>
            <Grid>
                <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
                <Border Background="#2E3140" CornerRadius="10" Padding="12" Margin="4">
                    <StackPanel>
                        <TextBlock Text="Из базы продуктов" FontWeight="Bold"/>
                        <ComboBox ItemsSource="{Binding Products}" SelectedItem="{Binding SelectedProduct}" DisplayMemberPath="Name"/>
                        <TextBlock Text="Вес (г)"/><TextBox Text="{Binding Weight}"/>
                        <TextBlock Text="Приём пищи"/><ComboBox ItemsSource="{Binding MealTypes}" SelectedItem="{Binding SelectedMealType}"/>
                        <TextBlock Text="Предпросмотр:" Margin="0,8,0,0"/>
                        <TextBlock Text="{Binding PreviewCalories, StringFormat='Калории: {0:0.0}'}"/>
                        <TextBlock Text="{Binding PreviewProtein, StringFormat='Белки: {0:0.0}'}"/>
                        <TextBlock Text="{Binding PreviewFat, StringFormat='Жиры: {0:0.0}'}"/>
                        <TextBlock Text="{Binding PreviewCarbs, StringFormat='Углеводы: {0:0.0}'}"/>
                        <Button Content="Добавить в дневник" Command="{Binding AddCommand}"/>
                    </StackPanel>
                </Border>
                <Border Grid.Column="1" Background="#2E3140" CornerRadius="10" Padding="12" Margin="4">
                    <StackPanel>
                        <TextBlock Text="Ручное добавление" FontWeight="Bold"/>
                        <TextBlock Text="Название"/><TextBox Text="{Binding ManualName}"/>
                        <TextBlock Text="Вес (г)"/><TextBox Text="{Binding ManualWeight}"/>
                        <TextBlock Text="Калории"/><TextBox Text="{Binding ManualCalories}"/>
                        <TextBlock Text="Белки"/><TextBox Text="{Binding ManualProtein}"/>
                        <TextBlock Text="Жиры"/><TextBox Text="{Binding ManualFat}"/>
                        <TextBlock Text="Углеводы"/><TextBox Text="{Binding ManualCarbs}"/>
                        <CheckBox Content="Сохранить этот продукт в базу" IsChecked="{Binding SaveManualToDatabase}" Margin="4"/>
                        <Button Content="Добавить вручную" Command="{Binding AddManualCommand}"/>
                    </StackPanel>
                </Border>
            </Grid>
        </StackPanel>
    </ScrollViewer>
</UserControl>
