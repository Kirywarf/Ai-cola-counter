<UserControl x:Class="CalorieCounter.Views.DiaryView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Grid>
        <Grid.RowDefinitions><RowDefinition Height="Auto"/><RowDefinition Height="*"/><RowDefinition Height="Auto"/></Grid.RowDefinitions>
        <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
            <DatePicker SelectedDate="{Binding SelectedDate}"/>
            <Button Content="Показать" Command="{Binding LoadCommand}"/>
            <Button Content="Сохранить изменения" Command="{Binding SaveCommand}"/>
            <Button Content="Удалить запись" Command="{Binding DeleteCommand}"/>
            <DatePicker SelectedDate="{Binding CopyTargetDate}"/>
            <Button Content="Копировать запись" Command="{Binding CopyCommand}"/>
            <Button Content="Повторить вчерашний рацион" Command="{Binding RepeatYesterdayCommand}"/>
        </StackPanel>
        <DataGrid Grid.Row="1" ItemsSource="{Binding Entries}" SelectedItem="{Binding SelectedEntry}" AutoGenerateColumns="False">
            <DataGrid.Columns>
                <DataGridTextColumn Header="Приём пищи" Binding="{Binding MealType}"/>
                <DataGridTextColumn Header="Продукт" Binding="{Binding ProductName}" Width="*"/>
                <DataGridTextColumn Header="Вес" Binding="{Binding WeightGrams}"/>
                <DataGridTextColumn Header="Ккал" Binding="{Binding Calories}"/>
                <DataGridTextColumn Header="Б" Binding="{Binding Protein}"/>
                <DataGridTextColumn Header="Ж" Binding="{Binding Fat}"/>
                <DataGridTextColumn Header="У" Binding="{Binding Carbs}"/>
            </DataGrid.Columns>
        </DataGrid>
        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,8,0,0">
            <TextBlock Text="{Binding TotalCalories, StringFormat='Калории: {0:0.0}'}" Margin="10,0"/>
            <TextBlock Text="{Binding TotalProtein, StringFormat='Белки: {0:0.0}'}" Margin="10,0"/>
            <TextBlock Text="{Binding TotalFat, StringFormat='Жиры: {0:0.0}'}" Margin="10,0"/>
            <TextBlock Text="{Binding TotalCarbs, StringFormat='Углеводы: {0:0.0}'}" Margin="10,0"/>
        </StackPanel>
    </Grid>
</UserControl>
