<Window x:Class="CalorieCounter.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="clr-namespace:CalorieCounter.ViewModels"
        xmlns:views="clr-namespace:CalorieCounter.Views"
        Title="Calorie Counter" Height="760" Width="1200" WindowStartupLocation="CenterScreen">
    <Window.Resources>
        <DataTemplate DataType="{x:Type vm:ProfileSelectionViewModel}"><views:ProfileSelectionView /></DataTemplate>
        <DataTemplate DataType="{x:Type vm:DashboardViewModel}"><views:DashboardView /></DataTemplate>
        <DataTemplate DataType="{x:Type vm:AddFoodViewModel}"><views:AddFoodView /></DataTemplate>
        <DataTemplate DataType="{x:Type vm:FoodDatabaseViewModel}"><views:FoodDatabaseView /></DataTemplate>
        <DataTemplate DataType="{x:Type vm:DiaryViewModel}"><views:DiaryView /></DataTemplate>
        <DataTemplate DataType="{x:Type vm:StatisticsViewModel}"><views:StatisticsView /></DataTemplate>
        <DataTemplate DataType="{x:Type vm:SettingsViewModel}"><views:SettingsView /></DataTemplate>
    </Window.Resources>

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="220"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <Border Background="#20222A" Padding="10">
            <StackPanel>
                <TextBlock Text="Calorie Counter" FontSize="26" FontWeight="Bold" Margin="8" />
                <TextBlock Text="{Binding ProfileHeader}" Margin="8,0,8,16" Foreground="#93D5FF"/>
                <Button Content="Главная" Command="{Binding NavigateCommand}" CommandParameter="Главная"/>
                <Button Content="Добавить еду" Command="{Binding NavigateCommand}" CommandParameter="Добавить еду"/>
                <Button Content="Дневник" Command="{Binding NavigateCommand}" CommandParameter="Дневник"/>
                <Button Content="База продуктов" Command="{Binding NavigateCommand}" CommandParameter="База продуктов"/>
                <Button Content="Статистика" Command="{Binding NavigateCommand}" CommandParameter="Статистика"/>
                <Button Content="Профили" Command="{Binding NavigateCommand}" CommandParameter="Профили"/>
                <Button Content="Настройки" Command="{Binding NavigateCommand}" CommandParameter="Настройки"/>
            </StackPanel>
        </Border>

        <Border Grid.Column="1" Margin="16" Background="#252833" CornerRadius="14" Padding="16">
            <ContentControl Content="{Binding CurrentViewModel}"/>
        </Border>
    </Grid>
</Window>
